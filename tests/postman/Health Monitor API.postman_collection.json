  "item": [
    {
      "name": "Services",
      "item": [
        {
          "name": "Create Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has expected fields\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"id\");\r",
                  "    pm.expect(json.name).to.eql(\"postman-test-service\");\r",
                  "    pm.expect(json.url).to.eql(\"http://example.com\");\r",
                  "});\r",
                  "\r",
                  "pm.environment.set(\"last_service_id\", pm.response.json().id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"postman-test-service\",\r\n  \"url\": \"http://example.com\",\r\n  \"check_interval_s\": 10\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/services",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "services"
              ]
            }
          },
          "response": []
        },
